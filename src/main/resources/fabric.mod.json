{
  "schemaVersion": 1,
  "id": "macrohub",
  "version": "${version}",
  "name": "MacroHub",
  "description": "In-game macro manager with fully customizable key sequences, delays, and hotkeys. Port of the AHK MacroHub script.",
  "authors": ["MacroHub"],
  "contact": {},
  "license": "MIT",
  "icon": "assets/macrohub/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "com.macrohub.MacroHubClient"
    ]
  },
  "mixins": [
    "macrohub.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.16.0",
    "minecraft": "~1.21.1",
    "java": ">=21",
    "fabric-api": "*"
  }
}
